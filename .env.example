# ─────────────────────────────────────────────────────────────────────────────
# LLM provider — pick ONE mode. Default = Mistral online (option A, active below).
# All modes are handled by src/llm_helpers.py with NO code change — env only.
# If no valid key is found, the agent falls back to an offline mock automatically.
# ─────────────────────────────────────────────────────────────────────────────

# ── A) Mistral ONLINE API  (DEFAULT preference) ─────────────────────────────
LLM_PROVIDER=mistral
LLM_MODEL=mistral-large-latest
MISTRAL_API_KEY=
#   Cheaper option: LLM_MODEL=mistral-small-latest

# ── B) Downloaded open-source model on a GPU, served with vLLM ───────────────
#   On a GPU box (e.g. Colab gpu_colab):
#     pip install vllm
#     python -m vllm.entrypoints.openai.api_server \
#         --model mistralai/Mistral-7B-Instruct-v0.3 --port 8000
#   then uncomment:
# LLM_PROVIDER=openai
# LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.3
# OPENAI_BASE_URL=http://localhost:8000/v1
# OPENAI_API_KEY=not-needed

# ── C) Ollama + a local model ───────────────────────────────────────────────
#     ollama serve            # (usually already running)
#     ollama pull mistral
#   then uncomment:
# LLM_PROVIDER=openai
# LLM_MODEL=mistral
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama

# ── D) OpenAI / Groq (any OpenAI-compatible cloud) ──────────────────────────
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=
# OPENAI_BASE_URL=            # e.g. https://api.groq.com/openai/v1 for Groq

# ── Retrieval (optional, GPU) ──────────────────────────────────────────────
# Real cross-encoder reranker (needs sentence-transformers + torch). Leave unset
# to use the simulated reranker so the repo runs on CPU / clean clone.
# USE_REAL_RERANKER=1
# RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── Observability: Langfuse (optional) ─────────────────────────────────────
# If unset, the agent runs with tracing disabled (no-op).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
